# Plantilla de secrets para Streamlit Cloud
# Copia este archivo como secrets.toml (sin .example) y rellena los valores

# Contraseña para acceder al panel del profesor
admin_password = "cambia_esta_contraseña"

# Email del profesor para reportes
professor_email = "henry.bojaca@gmail.com"

[email]
smtp_server = "smtp.gmail.com"
smtp_port = 587
sender_email = "tu_email@gmail.com"
sender_password = "app_password_de_gmail"  # NO tu password normal - usa App Password

# Opcional: Google Sheets como backend (si quieres compartir datos entre instancias)
# [gcp_service_account]
# type = "service_account"
# project_id = "..."
# private_key_id = "..."
# private_key = "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# client_email = "..."
